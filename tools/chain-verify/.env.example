# Copy to .env and adjust. The scripts read process.env directly (no dotenv autoload);
# either `export` these or prefix the command, e.g. `MOCK_ADDRESS=0x… pnpm run e2e:validation`.

# --- BigQuery (SDK only; the `bq`/`gcloud` CLIs are NOT required/installed) ---
# Service-account key. If unset, bqClient walks up for .secrets/gcp-key.json, then falls back
# to the sibling ../honeycomb/.secrets/gcp-key.json checkout.
GOOGLE_APPLICATION_CREDENTIALS=../honeycomb/.secrets/gcp-key.json
# Optional billing project override (else taken from the key's project_id).
# BQ_BILLING_PROJECT=
# Disposable test dataset + its fixture logs table. Defaults shown.
BQ_DATASET=honeycomb_test
BQ_LOGS_TABLE=honeycomb_test.logs
BQ_LOCATION=US

# --- Chain / indexer ---
# Anvil by default; point at a mainnet RPC to capture real ERC-8004 bytes instead.
ANVIL_RPC=http://127.0.0.1:8545
# ETH_RPC_URL=https://...           # takes precedence over ANVIL_RPC when set
# FROM_BLOCK=0                       # bound the getLogs range (required/sane for mainnet)
# TO_BLOCK=latest
# TOPIC0=0x...                       # optional: keep only logs with this topic0

# --- Assertions ---
# MOCK_ADDRESS=0x...                 # deployed mock address (or pass as the script arg)
# EXPECTED_COUNT=3                   # if set, e2e:validation fails unless the count matches
