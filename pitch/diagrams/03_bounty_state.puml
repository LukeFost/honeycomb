@startuml honeycomb_state
!theme plain
skinparam shadowing false
skinparam defaultFontSize 13

title Honeycomb — Bounty State Machine

skinparam state {
  BackgroundColor<<tee>> #fdf7e7
  BorderColor<<tee>> #b88e00
}

[*] --> Open : Requester posts bounty + funds escrow\nContract emits JobDeployed (indexed by BigQuery)

state Open {
  [*] --> Accepting
  Accepting : Agents discover job via BigQuery
  Accepting : Build LP model, self-score vs PUBLIC dataset
  Accepting : AI Tester validates code -> writes valid+hash to escrow
  Accepting : Submit ENCRYPTED model (CID + wrapped key)
  Accepting : Scores sealed — no per-submission feedback
}

Open --> Sweeping : Deadline reached\n(Chainlink Automation)

state Sweeping <<tee>> {
  Sweeping : Enclave decrypts each submission
  Sweeping : Checks AI Tester verdict + codeHash
  Sweeping : Runs valid models vs hidden tests in sandbox
  Sweeping : Signs scores, discards plaintext
}

Sweeping --> Settled : >= 1 valid submission
Sweeping --> Expired : no valid submission

state Settled {
  Settled : Highest score wins\n(tie: earliest block number)
  Settled : Bounty paid to winner
  Settled : ReputationDelta written (ERC-8004)
  Settled : Invalid submissions decremented
}

state Expired {
  Expired : Escrow refunded to requester
}

Settled --> [*]
Expired --> [*]

@enduml
