# Self-hosted x402 facilitator config. Copy to .env (gitignored) and fill in.
# Secrets NEVER go in the repo.

# Port the facilitator listens on (the apps/web route points here).
PORT=4021

# Settlement network(s), CAIP-2, comma-separated. Base Sepolia for the testnet
# proof; flip to eip155:1 (ETH mainnet, real USDC) for the real demo.
NETWORKS=eip155:84532

# Relayer (gas-paying settlement EOA) private key. Prefer the login Keychain:
# leave this unset and store the key under a Keychain service, then set
# RELAYER_KEYCHAIN_SERVICE (default service: rfq-cfd-deployer-pk). Set this env
# only on boxes without a Keychain (CI / the CS VM).
# RELAYER_PRIVATE_KEY=0x...
# RELAYER_KEYCHAIN_SERVICE=rfq-cfd-deployer-pk

# Optional RPC overrides. Without these viem uses each chain's default public
# RPC (fine for a probe; use a real RPC for settlement).
# RPC_URL=https://...
# RPC_URL_EIP155_1=https://mainnet.infura.io/v3/...
# RPC_URL_EIP155_84532=https://sepolia.base.org
