# CRE:
###############################################################################
### REQUIRED ENVIRONMENT VARIABLES - SENSITIVE INFORMATION                  ###
### DO NOT STORE RAW SECRETS HERE IN PLAINTEXT IF AVOIDABLE                 ###
### DO NOT UPLOAD OR SHARE THIS FILE UNDER ANY CIRCUMSTANCES                ###
###############################################################################
# Ethereum private key (raw 64-char hex, no 0x). Only needed for --broadcast.
CRE_ETH_PRIVATE_KEY=<YOUR_PRIVATE_KEY_GOES_HERE>
# Profile to use for this environment. Do not change for the demo.
CRE_TARGET=staging-settings
# Canonical Sepolia RPC. packages/chain/sepolia.ts resolves it in this order:
# SEPOLIA_RPC env -> RPC env -> macOS Keychain (honeycomb_sepolia_rpc) -> public node.
# On Luke's mac the Goldsky secret comes from Keychain; leave this unset there.
# Set it explicitly on CI / non-mac, e.g.:
# SEPOLIA_RPC=https://edge.goldsky.com/standard/evm/11155111?secret=<YOUR_GOLDSKY_SECRET>
