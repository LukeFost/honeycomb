# StrategyVault app — environment.
# Most secrets live in the repo-root ../../.env (REAL_MONEY_PKEY, UNISWAP_API_KEY, SEP_PRIVATE_KEY).

# --- fork tests (optional) ---
# Default to public RPCs; override for reliable archive nodes.
BASE_RPC_URL=https://base-rpc.publicnode.com
MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com

# --- real deploys / broadcasts on Base (real funds) ---
# REAL_MONEY_PKEY (in ../../.env) funds the deployer + pays gas. The deploy scripts read DEPLOYER_PK
# and the CRE broadcast reads CRE_ETH_PRIVATE_KEY (raw hex, no 0x) — both derived from REAL_MONEY_PKEY.
# See the README for the exact deploy + `cre workflow simulate --broadcast` commands.

# --- Uniswap Trading API key (CRE secret) ---
# UNISWAP_API_KEY is mapped to a CRE secret in strategy-workflow/secrets.yaml and read by the workflow.
# In `cre workflow simulate` it resolves from ../../.env via `-e ../../.env`.
UNISWAP_API_KEY=<your_uniswap_api_key>
