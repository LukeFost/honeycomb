# ERC-8004 BigQuery analysis — config template. Copy to .env and edit as needed.
#
# SECRETS: the only secret is the service-account JSON key. Put it at
#   honeycomb/.secrets/gcp-key.json   (gitignored; auto-discovered by bqenv.py)

# Billing project — optional. If unset, the service-account key's own project is used:
# BQ_BILLING_PROJECT=your-gcp-project-id

# Analysis window start (full history begins 2026-01-28):
BQ_START=2026-05-14

# Optional per-query byte cap:
# BQ_MAX_BYTES=70000000000

# Optional — set ONLY if your key is not at honeycomb/.secrets/gcp-key.json:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/gcp-key.json
